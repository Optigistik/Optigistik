rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function getUserRole() {
      return request.auth != null ? request.auth.token.role : null;
    }

    function isAuthenticated() {
      return request.auth != null;
    }

    match /users/{userId} {
      allow read: if isAuthenticated() && (request.auth.uid == userId || getUserRole() == 'Admin');
      allow write: if isAuthenticated() && getUserRole() == 'Admin';
    }

    match /tournees/{tourneeId} {
      allow read: if isAuthenticated() && (
        getUserRole() in ['Admin', 'Gestionnaire', 'Lecteur'] ||
        (getUserRole() == 'Chauffeur' && resource.data.driverId == request.auth.uid)
      );
      allow write: if isAuthenticated() && getUserRole() in ['Admin', 'Gestionnaire'];
    }

    match /vehicles/{vehicleId} {
      allow read: if isAuthenticated() && getUserRole() in ['Admin', 'Gestionnaire', 'Lecteur'];
      allow write: if isAuthenticated() && getUserRole() in ['Admin', 'Gestionnaire'];
    }

    match /typologies/{docId} {
      allow read: if isAuthenticated() && getUserRole() in ['Admin', 'Gestionnaire', 'Lecteur'];
      allow write: if isAuthenticated() && getUserRole() == 'Admin';
    }

    match /drivers/{driverId} {
      allow read: if isAuthenticated() && (
        getUserRole() in ['Admin', 'Gestionnaire', 'Lecteur'] ||
        (getUserRole() == 'Chauffeur' && request.auth.uid == driverId)
      );
      allow write: if isAuthenticated() && getUserRole() == 'Admin';
    }

    match /delivery_sessions/{sessionId} {
      allow read: if isAuthenticated() && getUserRole() in ['Admin', 'Gestionnaire', 'Lecteur'];
      allow write: if isAuthenticated() && getUserRole() in ['Admin', 'Gestionnaire'];
    }

    match /distance_matrices/{sessionId} {
      allow read: if isAuthenticated() && getUserRole() in ['Admin', 'Gestionnaire', 'Lecteur'];
      allow write: if isAuthenticated() && getUserRole() in ['Admin', 'Gestionnaire'];
    }

    match /solve_results/{sessionId} {
      allow read: if isAuthenticated() && getUserRole() in ['Admin', 'Gestionnaire', 'Lecteur'];
      allow write: if isAuthenticated() && getUserRole() in ['Admin', 'Gestionnaire'];
    }

  }
}
