rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Articles collection
    match /articles/{articleId} {
      // Anyone can read published articles
      allow read: if resource.data.status == 'published';
      
      // Only admins can read drafts
      allow read: if request.auth != null && 
                    exists(/databases/$(database)/documents/admins/$(request.auth.token.email));
      
      // Only admins can create, update, or delete articles
      allow create, update, delete: if request.auth != null && 
                                      exists(/databases/$(database)/documents/admins/$(request.auth.token.email));
    }
    
    // Admins collection
    match /admins/{email} {
      // Only authenticated users can read their own admin status
      allow read: if request.auth != null && request.auth.token.email == email;
      
      // No one can write to admins collection (must be done manually via Firebase Console)
      allow write: if false;
    }
  }
}
